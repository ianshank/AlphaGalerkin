{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "MPLBACKEND": "Agg",
    "WANDB_MODE": "disabled",
    "PYTHONHASHSEED": "0"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session_start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(mypy:*)",
      "Bash(pytest:*)",
      "Bash(python -m src.poc.cli:*)",
      "Bash(python -m src.agents.cli:*)",
      "Bash(python -m src.tools.verify_invariance:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git worktree:*)",
      "Bash(python -m scripts.audit_abstractions:*)"
    ]
  }
}
