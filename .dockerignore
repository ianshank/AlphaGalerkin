# .dockerignore - Files to exclude from Docker build context
#
# This reduces build context size and prevents sensitive files from
# being included in images.

# =============================================================================
# Git
# =============================================================================
.git
.gitignore
.gitattributes

# =============================================================================
# Python artifacts
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================================
# Virtual environments
# =============================================================================
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# =============================================================================
# IDE and editors
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-*

# =============================================================================
# Testing and coverage
# =============================================================================
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.hypothesis/
coverage.xml
*.cover
nosetests.xml

# =============================================================================
# Type checking
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json

# =============================================================================
# Documentation
# =============================================================================
docs/_build/
site/

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints
*.ipynb

# =============================================================================
# Model checkpoints and outputs (large files)
# =============================================================================
checkpoints/
outputs/
*.pt
*.pth
*.onnx
*.safetensors
models/
*.ckpt
wandb/

# =============================================================================
# Data files
# =============================================================================
data/
*.csv
*.json
!package.json
!tsconfig.json
*.parquet
*.h5
*.hdf5

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
hydra_outputs/

# =============================================================================
# Secrets and credentials
# =============================================================================
.env
.env.*
*.pem
*.key
credentials.json
secrets/
.secrets/

# =============================================================================
# OS files
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Docker
# =============================================================================
Dockerfile*
docker-compose*.yaml
docker-compose*.yml
!docker/
.docker/

# =============================================================================
# CI/CD
# =============================================================================
.github/
.gitlab-ci.yml
.circleci/
.travis.yml
Jenkinsfile
azure-pipelines.yml

# =============================================================================
# Documentation and metadata
# =============================================================================
README.md
CHANGELOG.md
CONTRIBUTING.md
LICENSE
*.md
!CLAUDE.md

# =============================================================================
# Test fixtures (keep small test data)
# =============================================================================
tests/fixtures/large/
tests/data/

# =============================================================================
# Temporary files
# =============================================================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# =============================================================================
# HuggingFace Space (separate deployment)
# =============================================================================
hf_space/
