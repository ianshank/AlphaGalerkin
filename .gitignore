.ruff_cache/

# Project specific
checkpoints/
outputs/
wandb/
*.pt
*.pth
*.log
*.dist-info/
nul

# Temporary coverage configs (generated per-session, never committed)
.coveragerc.*

# Chess engine binaries and output
stockfish*
*.pgn

# Hydra outputs
hydra_outputs/
multirun/

# Claude Code — ignore local/personal artifacts, but commit the shared
# project scaffolding (skills / subagents / commands / SessionStart hook /
# project settings) so Claude Code on the web + CLI can use them.
.claude/*
!.claude/skills/
!.claude/agents/
!.claude/commands/
!.claude/hooks/
!.claude/settings.json
.claude/settings.local.json

# Gradio dashboard cache and temporary files
gradio_cached_examples/
.gradio/
dashboard/__pycache__/
dashboard/tabs/__pycache__/

validation_outputs/

# Credentials and secrets
*.json
!package.json
!tsconfig.json
!tests/modeling/_public_surface_golden.json
!config/**/*.json
notebooks/utils/*.json
uv.lock

# SBIR / proposal outputs
outputs/sbir_benchmarks/
outputs/sbir_demo/
outputs/sbir_demo_v*/
outputs/sbir_p40/
outputs/sbir_p40_ns/
outputs/sbir_p40_ns_v*/
outputs/proposals/

# nvidia-smi dmon captures (one per profiled solve)
*.dmon

# Benchmark artifacts
*.benchmark
*.profile

# ML model formats (do not commit large binary model files)
*.safetensors
*.onnx
*.tflite
*.h5
*.hdf5
*.ckpt
*.engine
*.plan
*.trt

# TensorBoard / experiment tracking
runs/
lightning_logs/
mlruns/
.aim/

# Data directories (large datasets should not be committed)
data/raw/
data/processed/
data/external/
datasets/

# HuggingFace cache
.hf_cache/
hub/

# Environment variable files (beyond base .env)
.env.local
.env.development
.env.production
.env.test
.env.*.local

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Coverage / profiling artifacts
*.lcov
*.prof
prof/

# Configs with local overrides
configs/local/
config/local/

# Weights & Biases (catch alternate run-dir conventions)
.wandb/
wandb-summary.json
*.wdb

# Lock files for alternative package managers (we standardize on uv.lock)
poetry.lock
Pipfile.lock

# IDE / editor scratch
.vscode/
.idea/
*.swp
*.swo
*~

# Jupyter alternative checkpoint pattern
.ipynb_checkpoints

# AlphaGalerkin solver caches (local-only, not committed)
outputs/alphagalerkin_*/
outputs/trained_evaluator_*/

# Noyron HX scenario artifacts (Leap 71 integration)
# Captures model checkpoints, voxel-FDM caches, and scenario JSON results.
# The blanket ``outputs/`` rule above already covers these, but listing the
# scenario explicitly documents the on-disk layout for future readers.
outputs/poc/noyron_hx/
*.voxel
*.sdf

# LLM-Prior MCTS basis-selection ablation (LM Studio + Qwen-14B integration).
# Per-run HTML reports and JSON results are written under
# ``outputs/poc/llm_prior_ablation/``. The blanket ``outputs/`` rule covers
# them; the explicit entry documents the on-disk layout for future readers.
outputs/poc/llm_prior_ablation/

# Plan files generated by Claude Code in plan mode
.claude/plans/

# Re-assert the shared project settings after the broad `*.json` rule above
# (last matching pattern wins) so the committed .claude/settings.json is tracked.
!.claude/settings.json

# Coverage rcfiles emitted by CI workflow heredocs (regression-surface
# gates). Not source-of-truth — written at job time.
.coveragerc.noyron-hx
